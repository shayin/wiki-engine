# Wiki Cron 配置
# 复制为 config.sh 并修改

# ---- 推送 ----

# Bark 推送（填你的 Bark key，留空则不推送手机通知）
# 获取方式：App Store 下载 Bark，打开后复制 key
BARK_KEY=""
BARK_GROUP="Wiki"
BARK_SERVER="https://api.day.app"

# ---- 调度时间 ----

# digest: 每天处理 inbox 的时间（24小时制）
DIGEST_TIME="23:00"

# sweep: 知识库健康度扫描（星期 + 时间）
# 星期: Mon Tue Wed Thu Fri Sat Sun
SWEEP_DAY="Sat"
SWEEP_TIME="23:15"

# review: 决策复盘（每月几号 + 时间，逗号分隔）
REVIEW_DAYS="1,15"
REVIEW_TIME="23:15"

# todo-remind: 待办提醒（多个时间逗号分隔）
TODO_TIMES="11:00,23:00"
