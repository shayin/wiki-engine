# Wiki Cron 配置
# 复制为 config.sh 并修改

# ---- 推送 ----

# Bark 推送（填你的 Bark key，留空则不推送手机通知）
# 获取方式：App Store 下载 Bark，打开后复制 key
BARK_KEY=""
BARK_GROUP="Wiki"
BARK_SERVER="https://api.day.app"

# 微信推送（留空则不推送到微信）
# WECHAT_ID: 企业微信用户 ID（格式如 o9cq800CZjb8XStvFWGnLAhD7_s4@im.wechat）
# WECHAT_PUSH_KEY: 推送服务认证密钥
WECHAT_ID=""
WECHAT_PUSH_KEY=""
WECHAT_PUSH_SERVER=""

# ---- 调度时间 ----

# digest: 每天处理 inbox 的时间（24小时制）
DIGEST_TIME="23:00"

# sweep: 知识库健康度扫描（Daily = 每天，或指定星期几）
# 星期: Daily Mon Tue Wed Thu Fri Sat Sun
SWEEP_DAY="Daily"
SWEEP_TIME="23:15"

# review: 决策复盘（每天扫描到期决策）
REVIEW_TIME="23:15"

# todo-remind: 待办提醒（多个时间逗号分隔）
TODO_TIMES="11:00,23:00"

# 事件日历扫描（早晚各一次，event-calendar-check.sh）
EVENT_CALENDAR_TIMES="11:30,19:00"
